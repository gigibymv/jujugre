# Client: default is OFF (JSON reply). Set true only if you want token streaming in the UI.
# NEXT_PUBLIC_COACH_USE_STREAM=true

# Upstream LLM: abort after N ms so Vercel Hobby (~10s) returns a fallback instead of 504 HTML.
# COACH_UPSTREAM_TIMEOUT_MS=8200
# On Vercel only: allow OpenAI/NVIDIA SSE (fragile on Hobby). Default is JSON upstream on Vercel.
# COACH_VERCEL_ALLOW_UPSTREAM_SSE=true

# Coach — prefer OpenRouter (free models). https://openrouter.ai/keys
OPENROUTER_API_KEY=
# Optional: comma-separated model ids (default = 3 free models in order)
# OPENROUTER_MODEL_CHAIN=google/gemma-4-31b-it:free,openai/gpt-oss-120b:free,nvidia/nemotron-3-nano-30b-a3b:free
# OPENROUTER_MAX_TOKENS=1024
# OPENROUTER_HTTP_REFERER=https://your-site.vercel.app
# OPENROUTER_APP_TITLE=Jujugre

# Optional — coach fallback: NVIDIA NIM: https://build.nvidia.com/
NVIDIA_API_KEY=
# NVIDIA_MODEL=google/gemma-4-31b-it
# Smaller max_tokens = faster replies (default 1024 when COACH_VERBOSE is off)
# NVIDIA_MAX_TOKENS=1024
# NVIDIA_TEMPERATURE=0.55
# NVIDIA_TOP_P=0.92
# Set true only if you accept much slower responses (hidden reasoning phase)
# NVIDIA_ENABLE_THINKING=false

# Longer, slower answers (400–900 word style + higher token cap)
# COACH_VERBOSE=false

# Optional — coach fallback if OpenRouter + NVIDIA fail or are unset
# OPENAI_API_KEY=
# OPENAI_MODEL=gpt-4o-mini
# OPENAI_MAX_TOKENS=900

# Optional — cloud sync for study plan API only (UI uses localStorage by default)
# NEXT_PUBLIC_SUPABASE_URL=
# NEXT_PUBLIC_SUPABASE_ANON_KEY=

# Google Stitch MCP (Cursor). Put STITCH_API_KEY in .env.local — .cursor/mcp.json uses envFile (workspace .env.local).
# Setup: https://stitch.withgoogle.com/docs/mcp/setup — API key in Stitch settings (skips OAuth when set).
STITCH_API_KEY=
# Optional: use your machine’s gcloud instead of the CLI’s bundled auth (see @_davideast/stitch-mcp README).
# STITCH_USE_SYSTEM_GCLOUD=1
